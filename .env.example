# Public app URL used for auth callbacks and absolute metadata.
APP_URL="http://localhost:3000"

# NextAuth session encryption secret.
AUTH_SECRET="replace-with-a-long-random-secret"

# Gemini API key used by the AI helper flows in `lib/ai.ts`.
NEXT_PUBLIC_GEMINI_API_KEY="replace-with-your-gemini-api-key"

# Optional server host/port overrides for local or container runtime.
HOSTNAME="0.0.0.0"
PORT="3000"

# Optional comma-separated CORS allowlist for Socket.IO clients.
SOCKET_ALLOWED_ORIGINS="http://localhost:3000"
